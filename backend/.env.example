PORT=3001

# Path to the whisper.cpp CLI binary
WHISPER_BIN=/opt/homebrew/bin/whisper-cli

# Path to the GGML model file
WHISPER_MODEL=./models/ggml-small.bin

# Path to ffmpeg binary (used to convert browser recordings to 16kHz mono WAV)
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg

# Whisper language hint: 'auto', 'ru', 'en', etc.
WHISPER_LANGUAGE=auto

# Ollama server
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Home Assistant (Profile -> Security -> Long-Lived Access Tokens, to
# generate HA_TOKEN)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Path to the LLM system prompt file (defaults to ../system_prompt, i.e.
# the repo root)
SYSTEM_PROMPT_PATH=
