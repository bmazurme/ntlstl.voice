PORT=3001

# Path to the whisper.cpp CLI binary
WHISPER_BIN=/opt/homebrew/bin/whisper-cli

# Path to the GGML model file
WHISPER_MODEL=./models/ggml-small.bin

# Path to ffmpeg binary (used to convert browser recordings to 16kHz mono WAV)
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg

# Whisper language hint: 'auto', 'ru', 'en', etc.
WHISPER_LANGUAGE=auto

# Path to the Piper TTS binary (speaks the LLM's response_text back through
# the ESP32-P4's speaker, via POST /api/tts). On Linux, a release binary
# from https://github.com/rhasspy/piper/releases (piper_linux_*.tar.gz)
# works fine. On macOS, skip the GitHub release - the "aarch64" build is
# mislabeled x86_64 and won't run natively on Apple Silicon (repo is
# archived, so this won't get fixed) - install the PyPI package instead,
# which has proper arm64 wheels:
#   python3 -m venv /opt/homebrew/piper-venv && /opt/homebrew/piper-venv/bin/pip install piper-tts
PIPER_BIN=/opt/homebrew/piper-venv/bin/piper

# Path to the Piper voice model (.onnx). Needs the matching .onnx.json
# right next to it. Example (Russian, medium quality):
#   curl -L -o backend/models/ru_RU-irina-medium.onnx \
#     https://huggingface.co/rhasspy/piper-voices/resolve/main/ru/ru_RU/irina/medium/ru_RU-irina-medium.onnx
#   curl -L -o backend/models/ru_RU-irina-medium.onnx.json \
#     https://huggingface.co/rhasspy/piper-voices/resolve/main/ru/ru_RU/irina/medium/ru_RU-irina-medium.onnx.json
PIPER_MODEL=./models/ru_RU-irina-medium.onnx

# Ollama server
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Home Assistant (Profile -> Security -> Long-Lived Access Tokens, to
# generate HA_TOKEN)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Path to the LLM system prompt file (defaults to ../system_prompt, i.e.
# the repo root)
SYSTEM_PROMPT_PATH=
